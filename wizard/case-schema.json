        {
          "id": "secondary_outputs",
          "label": "Output secondari derivabili",
          "type": "multi_select",
          "required": false,
          "multiple": true,
          "options": [
            "slide_brief",
            "mail_brief",
            "locandina_brief",
            "pagina_evento_brief",
            "canva_brief",
            "checklist_docente",
            "followup_brief"
          ]
        },
        {
          "id": "material_generation_scope",
          "label": "Ampiezza della generazione derivata",
          "type": "single_select",
          "required": true,
          "multiple": false,
          "options": [
            "solo_script_master",
            "script_master_e_brief_essenziali",
