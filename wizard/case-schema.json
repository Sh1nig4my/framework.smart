        },
        {
          "id": "accessibility_profile",
          "label": "Requisiti di accessibilita comunicativa",
          "type": "multi_select",
          "required": true,
          "multiple": true,
          "options": [
            "linguaggio_semplice",
            "glossario_implicito",
            "esempi_concreti",
            "passaggi_graduali",
            "riduzione_jargon",
            "ritmo_moderato"
          ]
        },
        {
          "id": "excluded_elements",
          "label": "Elementi da evitare",
          "type": "multi_select",
          "required": false,
          "multiple": true,
          "options": [
            "eccesso_tecnico",
            "taglio_commerciale",
            "demo_complesse",
            "tool_troppo_specialistici",
            "contenuti_astratti",
            "tono_sensazionalistico"
          ]
        }
      ]
    },
    {
      "id": "generation_targets",
      "label": "Output attesi",
      "fields": [
        {
          "id": "primary_output",
          "label": "Output principale",
          "type": "single_select",
          "required": true,
          "multiple": false,
          "options": [
            "script_master"
